# ── Schedule ──────────────────────────────────────────────────────────────────
SCHEDULE_TIME=15:00

# ── Active sources (comma-separated, order = pipeline order) ──────────────────
# Options: youtube, twitch, reddit, podcast, article
ACTIVE_SOURCES=youtube,reddit,podcast

# ── YouTube ───────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=UC4VPa7EOvObpyCRI4YKRQRw

# ── Twitch ────────────────────────────────────────────────────────────────────
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TWITCH_STREAMER_LOGIN=your_streamer_name

# ── Reddit ────────────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=MIDAS/1.0
REDDIT_SUBREDDIT=technology

# ── Podcast (RSS) ─────────────────────────────────────────────────────────────
PODCAST_RSS_URL=https://feeds.simplecast.com/your_podcast_feed

# ── Article / Blog / Substack ─────────────────────────────────────────────────
ARTICLE_RSS_URL=https://yourblog.substack.com/feed

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here   # used for Whisper audio transcription

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here
